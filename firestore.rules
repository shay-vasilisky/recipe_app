rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedEmail() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          "shayvasa@gmail.com",
          "morhadjes@gmail.com"
        ];
    }

    match /recipes/{recipeId} {
      allow read, write: if isAllowedEmail();

      match /comments/{commentId} {
        allow read: if isAllowedEmail();
        allow create: if isAllowedEmail()
          && request.resource.data.authorEmail == request.auth.token.email;
        allow update: if isAllowedEmail()
          && resource.data.authorEmail == request.auth.token.email
          && request.resource.data.authorEmail == resource.data.authorEmail;
        allow delete: if isAllowedEmail()
          && resource.data.authorEmail == request.auth.token.email;
      }
    }

    match /tags/{tagId} {
      allow read, write: if isAllowedEmail();
    }
  }
}
